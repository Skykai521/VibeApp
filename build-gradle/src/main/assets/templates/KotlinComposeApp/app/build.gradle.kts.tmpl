plugins {
    alias(libs.plugins.android.application)
    // AGP 9.x has built-in Kotlin support; no separate kotlin.android plugin.
    alias(libs.plugins.kotlin.compose)
    // Tencent Shadow plugin. Adds a "Shadow" flavor dimension with two
    // flavors (normal / plugin); only the plugin flavor gets Shadow's
    // bytecode transform. Use `:app:assemblePluginDebug` to produce the
    // Shadow-loadable APK.
    alias(libs.plugins.shadow)
}

shadow {
    // `transform` is the configure method on ShadowExtension (wraps the
    // `transformConfig: TransformConfig` property via an Action). Do NOT
    // write `transformConfig { }` directly — that's Groovy DSL sugar
    // Kotlin DSL doesn't resolve.
    //
    // `useHostContext` rules (intentionally left empty) take the form
    // "<class>.<method>(<paramTypes>)$<argIndex>" — Shadow wraps the
    // listed argument with `((ShadowContext)$N).getBaseContext()` so the
    // call receives the host's Context instead of the plugin's. Most
    // Compose-only plugins don't need any rewrites; add one here only if
    // the plugin calls into a host API that genuinely requires the host
    // Context (rare).
    transform { }
}

android {
    namespace = "{{PACKAGE_NAME}}"
    compileSdk = 34

    defaultConfig {
        applicationId = "{{PACKAGE_NAME}}"
        // minSdk must be > 26 (Android O) so Shadow's checkAaptPackageIdConfig
        // accepts the --package-id 0x80 we use for plugin resources. The
        // host app itself is minSdk=29, so plugins never run on lower
        // versions — keeping this >26 has no real coverage cost.
        minSdk = 27
        targetSdk = 34
        versionCode = 1
        versionName = "1.0"
    }

    buildTypes {
