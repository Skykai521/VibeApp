<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 2c test NSC: permit cleartext http to emulator loopback 10.0.2.2
     (the dev bootstrap server) as well as localhost. AGP's default test NSC
     only whitelists localhost, blocking our dev server calls. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
