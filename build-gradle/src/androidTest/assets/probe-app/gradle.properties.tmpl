# Rendered by ProjectStager (.tmpl suffix is stripped on copy).
#
# Memory budget for the on-device Android emulator/device. 640m heap +
# 256m metaspace keeps us within a 2GB emulator's working set; a real
# phone with 4GB+ just runs it faster.
org.gradle.jvmargs=-Xmx640m -XX:MaxMetaspaceSize=256m
kotlin.daemon.jvm.options=-Xmx384m
org.gradle.parallel=false
org.gradle.caching=false

android.useAndroidX=true
android.nonTransitiveRClass=true

# AGP 9.1.0's default `aapt2:jar:linux` Maven artifact ships an x86_64
# ELF binary that can't exec under Android's arm64 linker. Force AGP to
# use the arm64 aapt2 bundled in our on-device SDK tarball instead.
android.aapt2FromMavenOverride={{SDK_DIR}}/build-tools/36.0.0/aapt2

# No configuration cache for Phase 2d — keeps failure modes simple.
org.gradle.configuration-cache=false
