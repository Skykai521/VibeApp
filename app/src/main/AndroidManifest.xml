<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <queries>
        <package android:name="com.google.android.aicore" />
        <package android:name="com.google.android.as.oss" />
    </queries>

    <application
        android:name="com.vibe.app.presentation.VibeApp"
        android:allowBackup="true"
        android:largeHeap="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        tools:targetApi="upside_down_cake">
        <activity
            android:name="com.vibe.app.presentation.ui.main.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.VibeApp.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name="com.vibe.app.feature.agent.service.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Plugin process slots (0-4): each in its own process with separate task affinity -->
        <activity
            android:name="com.vibe.app.plugin.legacy.PluginSlot0"
            android:process=":plugin0"
            android:taskAffinity="com.vibe.app.plugin0"
            android:launchMode="singleTask"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />
        <activity
            android:name="com.vibe.app.plugin.legacy.PluginSlot1"
            android:process=":plugin1"
            android:taskAffinity="com.vibe.app.plugin1"
            android:launchMode="singleTask"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />
        <activity
            android:name="com.vibe.app.plugin.legacy.PluginSlot2"
            android:process=":plugin2"
            android:taskAffinity="com.vibe.app.plugin2"
            android:launchMode="singleTask"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />
        <activity
            android:name="com.vibe.app.plugin.legacy.PluginSlot3"
            android:process=":plugin3"
            android:taskAffinity="com.vibe.app.plugin3"
            android:launchMode="singleTask"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />
        <activity
            android:name="com.vibe.app.plugin.legacy.PluginSlot4"
            android:process=":plugin4"
            android:taskAffinity="com.vibe.app.plugin4"
            android:launchMode="singleTask"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />
        <!-- Plugin inspector services (0-4): each in matching plugin process -->
        <service
            android:name="com.vibe.app.plugin.legacy.PluginInspectorSlot0"
            android:process=":plugin0"
            android:exported="false" />
        <service
            android:name="com.vibe.app.plugin.legacy.PluginInspectorSlot1"
            android:process=":plugin1"
            android:exported="false" />
        <service
            android:name="com.vibe.app.plugin.legacy.PluginInspectorSlot2"
            android:process=":plugin2"
            android:exported="false" />
        <service
            android:name="com.vibe.app.plugin.legacy.PluginInspectorSlot3"
            android:process=":plugin3"
            android:exported="false" />
        <service
            android:name="com.vibe.app.plugin.legacy.PluginInspectorSlot4"
            android:process=":plugin4"
            android:exported="false" />

        <!-- v2 Shadow plugin host (Phase 5b-4). Single dedicated process
             for now; the legacy 5-slot model is preserved above while
             the Shadow path stabilises. Move to :shadow_plugin0..4 if
             we port the LRU slot policy onto Shadow. -->
        <service
            android:name="com.vibe.app.plugin.v2.ShadowPluginProcessService"
            android:process=":shadow_plugin"
            android:exported="false" />

        <!-- v2 inspector Service (Phase 5b-7). Runs in the same
             :shadow_plugin process as Shadow's PPS + the plugin Activity,
             so it can reach the Activity's decor view directly. -->
        <service
            android:name="com.vibe.app.plugin.v2.ShadowPluginInspectorService"
            android:process=":shadow_plugin"
            android:exported="false" />
    </application>

</manifest>