<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <queries>
        <package android:name="com.google.android.aicore" />
        <package android:name="com.google.android.as.oss" />
    </queries>

    <application
        android:name="com.vibe.app.presentation.VibeApp"
        android:allowBackup="true"
        android:largeHeap="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        tools:targetApi="upside_down_cake">
        <activity
            android:name="com.vibe.app.presentation.ui.main.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.VibeApp.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name="com.vibe.app.feature.agent.service.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- v2 Shadow plugin host. All plugin APKs load into one dedicated
             process via Tencent Shadow's PluginProcessService. -->
        <service
            android:name="com.vibe.app.plugin.v2.ShadowPluginProcessService"
            android:process=":shadow_plugin"
            android:exported="false" />

        <!-- v2 inspector Service. Shares the :shadow_plugin process with
             the PPS + the running plugin Activity, so it can walk the
             Activity's decor view directly. -->
        <service
            android:name="com.vibe.app.plugin.v2.ShadowPluginInspectorService"
            android:process=":shadow_plugin"
            android:exported="false" />

        <!-- Shadow's container Activity. Plugin Activities are routed here
             by VibeAppComponentManager.onBindContainerActivity — the
             container then delegates onCreate / lifecycle / touches to the
             actual plugin Activity instance via Shadow's runtime. Must run
             in the same `:shadow_plugin` process as the plugin code. -->
        <activity
            android:name="com.tencent.shadow.core.runtime.container.PluginContainerActivity"
            android:process=":shadow_plugin"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|locale|layoutDirection|fontScale|uiMode" />
    </application>

</manifest>