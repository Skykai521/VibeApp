# Git worktrees (subagent-driven-development)
/.worktrees

/.obsidian

# Bootstrap artifact staging (built by scripts/bootstrap/build-*.sh;
# large, derived, never committed).
/scripts/bootstrap/artifacts
# Bootstrap artifacts copied into the APK by copyBootstrapArtifacts.
# Source of truth is scripts/bootstrap/artifacts/.
/app/src/main/assets/bootstrap/

# Gradle build outputs for the pure-JVM :gradle-host module
/gradle-host/build/

# GradleHost shaded JAR, copied from gradle-host/build/libs at build time.
/app/src/main/assets/vibeapp-gradle-host.jar
# GradleHost JAR copied into build-gradle's androidTest assets
/build-gradle/src/androidTest/assets/vibeapp-gradle-host.jar

# Claude Code session-local state
/.claude

# Build outputs for vendored Shadow modules (source committed, build/ not)
/third_party/shadow/codegen-runner/build/
/third_party/shadow/java-build-config/build/
/third_party/shadow/loader-apk/build/
/third_party/shadow/runtime-apk/build/
/third_party/shadow/upstream/**/build/
